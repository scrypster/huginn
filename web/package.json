    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@tiptap/vue-3": "^3.20.1",
    "@types/dompurify": "^3.0.5",
    "@vueuse/core": "^14.2.1",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "marked": "^17.0.4",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.9.0",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
