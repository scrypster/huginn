.fuse_hidden*

# Transpiled Vue SFC artifacts (generated by build tools)
web/src/**/*.vue.js

# Stale TypeScript compiler emit. Source-of-truth is .ts/.vue; the
# build pipeline (vue-tsc -b && vite build) does not require these to
# be checked in. If a hand-written .js ever needs to live alongside a
# .ts twin, add an explicit !path/to/file.js override below.
web/src/**/*.js
web/src/**/*.js.map
web/src/**/*.d.ts
web/src/**/*.d.ts.map

# Temp build artifacts
huginn-go-tmp-umask
huginn_bin*
