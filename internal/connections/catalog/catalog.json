        "key": "url",
        "label": "Site",
        "type": "select",
        "required": false,
        "stored_in": "metadata",
        "help_text": "Select your Datadog site region or enter a custom URL.",
        "default": "https://api.datadoghq.com",
        "options": [
          { "label": "US1 (datadoghq.com)",        "value": "https://api.datadoghq.com" },
          { "label": "US3 (us3.datadoghq.com)",     "value": "https://api.us3.datadoghq.com" },
          { "label": "US5 (us5.datadoghq.com)",     "value": "https://api.us5.datadoghq.com" },
          { "label": "EU1 (datadoghq.eu)",          "value": "https://api.datadoghq.eu" },
          { "label": "AP1 (ap1.datadoghq.com)",     "value": "https://api.ap1.datadoghq.com" },
          { "label": "Custom URL",                   "value": "__custom__" }
        ]
      },
      {
        "key": "api_key",
        "label": "API Key",
        "type": "password",
        "required": true,
        "stored_in": "creds",
        "placeholder": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "help_text": "Found under Organization Settings → API Keys."
      },
      {
        "key": "app_key",
        "label": "Application Key",
        "type": "password",
        "required": true,
        "stored_in": "creds",
        "placeholder": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
        "help_text": "Found under Organization Settings → Application Keys. Needed for write operations."
      }
    ],
    "validation": {
      "available": true,
      "description": "Calls GET /api/v1/validate with your API and application keys."
    }
  },
